# 云托管建议环境变量
ASR_HOST=0.0.0.0
PORT=8765
ASR_OUTPUT_DIR=/tmp/output
PHI3_FIRST=0
LOCAL_ASR_ENABLED=0

# 本机与机器人网络配置# 172.18.1.79
BACKEND_LOCAL_IP= 192.168.1.132
ROBOT_IP=192.168.1.28
ROBOT_CMD_PORT=3336
ROBOT_STATE_PORT=3333
ROBOT_MODE_PORT=4141

# 智谱 GLM-ASR-2512 配置
ZHIPU_API_KEY=a63fa55209e348258bf176ad42d3a2a1.RXabvjuX7g10YPZD
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4
ZHIPU_ASR_MODEL=glm-asr-2512

# 兜底占位标签
FALLBACK_MODEL=phi3

# 数据回流规范默认值
REFLOW_COORD_SYS=slam_local
REFLOW_POSE_SOURCE=robot
REFLOW_SPACE_VERSION=scene_market_v1.0
REFLOW_COORD_NOTE=任务起点为 SLAM/里程计原点
REFLOW_TASK_ID=EVAL-D-20260614

# ROS2 相机订阅与录像
CAMERA_ROS2_ENABLED=1
HEAD_CAMERA_TOPIC=/camera/head/image_raw/compressed
LEFT_CAMERA_TOPIC=/camera/left/image_raw/compressed
RIGHT_CAMERA_TOPIC=/camera/right/image_raw/compressed
CAMERA_RECORD_FPS=12
CAMERA_RECORD_DIR=../output/camera
REFLOW_MEDIA_DIR=../output/reflow_buffer

# 赛星回流 API 配置
REFLOW_ENABLED=1
REFLOW_BASE_URL=https://fuxingdao.sh-aia.com
REFLOW_LOGIN_NAME=team66
REFLOW_PASSWORD=replace_with_team66_password
REFLOW_TIMEOUT_S=20
REFLOW_VERIFY_SSL=1
REFLOW_TEAM_ID=team66
REFLOW_ROBOT_ID=R-team66-01
REFLOW_SCENE_ID=market
REFLOW_TASK_PREFIX=EVAL-D
REFLOW_BATCH_MAX=200
REFLOW_VALIDATE_TEAM_BINDING=1

# 市集导购任务编排配置
MISSION_ENABLED=1
MISSION_DRY_RUN=1
MISSION_DEFAULT_SPEED_MPS=0.18
MISSION_AUTO_REFLOW=1
