# 云托管建议环境变量
ASR_HOST=0.0.0.0
PORT=8765
ASR_OUTPUT_DIR=/tmp/output
PHI3_FIRST=0
LOCAL_ASR_ENABLED=0

# 本机与机器人网络配置# 172.18.1.79
BACKEND_LOCAL_IP= 192.168.1.132
ROBOT_IP=192.168.1.28
ROBOT_CMD_PORT=3336
ROBOT_STATE_PORT=3333
ROBOT_MODE_PORT=4141

# 智谱 GLM-ASR-2512 配置
ZHIPU_API_KEY=a63fa55209e348258bf176ad42d3a2a1.RXabvjuX7g10YPZD
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4
ZHIPU_ASR_MODEL=glm-asr-2512

# 兜底占位标签
FALLBACK_MODEL=phi3

# 数据回流规范默认值
REFLOW_COORD_SYS=slam_local
REFLOW_POSE_SOURCE=robot
REFLOW_SPACE_VERSION=scene_market_v1.0
REFLOW_COORD_NOTE=任务起点为 SLAM/里程计原点
REFLOW_TASK_ID=EVAL-D-20260614

# ROS2 相机订阅与录像
CAMERA_ROS2_ENABLED=1
HEAD_CAMERA_TOPIC=/camera/head/image_raw/compressed
LEFT_CAMERA_TOPIC=/camera/left/image_raw/compressed
RIGHT_CAMERA_TOPIC=/camera/right/image_raw/compressed
CAMERA_RECORD_FPS=12
CAMERA_RECORD_DIR=../output/camera
REFLOW_MEDIA_DIR=../output/reflow_buffer

# 赛星回流 API 配置
REFLOW_ENABLED=1
REFLOW_BASE_URL=https://fuxingdao.sh-aia.com
REFLOW_LOGIN_NAME=team66
REFLOW_PASSWORD=replace_with_team66_password
REFLOW_TIMEOUT_S=20
REFLOW_VERIFY_SSL=1
REFLOW_TEAM_ID=team66
REFLOW_ROBOT_ID=R-team66-01
REFLOW_SCENE_ID=market
REFLOW_TASK_PREFIX=EVAL-D
REFLOW_BATCH_MAX=200
REFLOW_VALIDATE_TEAM_BINDING=1

# 市集导购任务编排配置
MISSION_ENABLED=1
MISSION_DRY_RUN=1
MISSION_DEFAULT_SPEED_MPS=0.18
MISSION_AUTO_REFLOW=1

# 末端位姿精调安全参数（UI 微调接口 /robot/arm/eef_adjust）
ROBOT_EEF_ADJUST_ENABLED=1
ROBOT_EEF_ADJUST_DEFAULT_SEND_TIME_S=0.45
ROBOT_EEF_ADJUST_SEND_TIME_MIN_S=0.15
ROBOT_EEF_ADJUST_SEND_TIME_MAX_S=2.0
ROBOT_EEF_ADJUST_MAX_DELTA_POS_M=0.06
ROBOT_EEF_ADJUST_MAX_DELTA_ATT_RAD=0.35
ROBOT_EEF_X_MIN=0.22
ROBOT_EEF_X_MAX=0.65
ROBOT_EEF_Z_MIN=0.52
ROBOT_EEF_Z_MAX=0.95
ROBOT_EEF_LEFT_Y_MIN=0.12
ROBOT_EEF_LEFT_Y_MAX=0.45
ROBOT_EEF_RIGHT_Y_MIN=-0.45
ROBOT_EEF_RIGHT_Y_MAX=-0.12
ROBOT_EEF_ROLL_MIN=-1.57
ROBOT_EEF_ROLL_MAX=1.57
ROBOT_EEF_PITCH_MIN=-1.57
ROBOT_EEF_PITCH_MAX=1.57
ROBOT_EEF_YAW_MIN=-1.57
ROBOT_EEF_YAW_MAX=1.57
ROBOT_EEF_FEEDBACK_POS_TOL_M=0.03
ROBOT_EEF_FEEDBACK_ATT_TOL_RAD=0.25

# 阻力保护（基于关节力矩 tau）：行进与手臂前伸超阈值自动急停
# 默认按“室内平整水泥地面（免现场标定）”稳妥档配置：
# - 稳定优先，先降低误触发概率；后续若有时间可再逐步下调阈值提升灵敏度。
ROBOT_RESIST_GUARD_ENABLED=1
ROBOT_RESIST_GUARD_MOVE_ENABLED=1
ROBOT_RESIST_GUARD_ARM_EXTEND_ENABLED=1
ROBOT_RESIST_TAU_THRESHOLD_MOVE_NM=30.0
ROBOT_RESIST_TAU_THRESHOLD_ARM_NM=24.0
ROBOT_RESIST_CONSECUTIVE_HITS=4
ROBOT_RESIST_SAMPLE_INTERVAL_S=0.03
