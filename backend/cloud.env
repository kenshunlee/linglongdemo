# 本地私有环境变量
#
# 说明：敏感值请放到 `cloud.env.local`，本文件仅保留本地非敏感配置。
ASR_HOST=0.0.0.0
PORT=8765
ASR_OUTPUT_DIR=/tmp/output
PHI3_FIRST=0
LOCAL_ASR_ENABLED=0

# 本机与机器人网络配置 //172.18.1.79    
BACKEND_LOCAL_IP=192.168.1.132
ROBOT_IP=192.168.1.28
ROBOT_CMD_PORT=3336
ROBOT_STATE_PORT=3333
ROBOT_MODE_PORT=4141

# 智谱 GLM-ASR-2512 配置
ZHIPU_API_KEY=replace_with_your_private_key
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4
ZHIPU_ASR_MODEL=glm-asr-2512
ZHIPU_VISION_MODEL=glm-4.6v-flash

# 兜底占位标签
FALLBACK_MODEL=phi3
