/* pages/history/history.wxss */

.container { padding: 20rpx; }

/* 统计卡片 */
.stat-card {
  display: flex;
  align-items: center;
  justify-content: space-around;
  padding: 28rpx 20rpx;
  margin-bottom: 20rpx;
}
.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}
.stat-num   { font-size: 48rpx; font-weight: 700; color: #1a73e8; }
.stat-label { font-size: 24rpx; color: #999; margin-top: 4rpx; }
.stat-divider {
  width: 1rpx;
  height: 60rpx;
  background: #eee;
}
.refresh-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  cursor: pointer;
}
.refresh-icon { font-size: 40rpx; }
.refresh-label { font-size: 24rpx; color: #999; margin-top: 4rpx; }
.spin { animation: spin 1s linear infinite; }
@keyframes spin { to { transform: rotate(360deg); } }

/* 加载 */
.loading-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
}
.spinner-sm {
  width: 48rpx; height: 48rpx;
  border: 4rpx solid #eee;
  border-top-color: #1a73e8;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 16rpx;
}
.loading-text { font-size: 28rpx; color: #999; }

/* 空状态 */
.empty-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}
.empty-icon { font-size: 80rpx; margin-bottom: 20rpx; }
.empty-text { font-size: 32rpx; color: #666; margin-bottom: 12rpx; }
.empty-sub  { font-size: 26rpx; color: #bbb; }

/* 列表 */
.list-scroll { height: calc(100vh - 260rpx); }
.record-item {
  margin-bottom: 16rpx;
  cursor: pointer;
  transition: transform 0.1s;
}
.record-item:active { transform: scale(0.99); }
.item-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10rpx;
}
.item-filename { font-size: 26rpx; color: #1a73e8; font-family: monospace; font-weight: 600; }
.item-size     { font-size: 22rpx; color: #bbb; }
.item-time     { font-size: 24rpx; color: #aaa; margin-bottom: 12rpx; }
.preview-text  { font-size: 26rpx; color: #555; line-height: 1.6; }
.no-preview-text { font-size: 24rpx; color: #ccc; font-style: italic; }

/* 详情弹窗 */
.modal-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.5);
  display: flex;
  align-items: flex-end;
  z-index: 999;
}
.detail-box {
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  padding: 32rpx;
  width: 100%;
  max-height: 75vh;
  display: flex;
  flex-direction: column;
}
.detail-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}
.detail-filename {
  font-size: 28rpx;
  font-weight: 600;
  color: #1a73e8;
  font-family: monospace;
  flex: 1;
}
.detail-close {
  font-size: 40rpx;
  color: #999;
  padding: 0 10rpx;
}
.detail-scroll { flex: 1; margin-bottom: 20rpx; }
.detail-text   { font-size: 28rpx; line-height: 1.8; color: #333; }
.detail-actions { display: flex; justify-content: flex-end; }
.btn-copy { background: #1a73e8 !important; color: #fff !important; border-radius: 8rpx !important; }
