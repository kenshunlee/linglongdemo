<view class="container">
  <view class="card">
    <view class="row">
      <text class="title">机器人状态</text>
      <text class="badge {{robotReady ? 'badge-success' : 'badge-error'}}">{{robotReady ? 'SDK可用' : 'SDK不可用'}}</text>
    </view>
    <text class="hint">{{sdkReason}}</text>
    <button class="btn btn-ghost" bindtap="refreshHealth" loading="{{busy}}"><text class="btn-icon">↺</text><text class="btn-label">刷新状态</text></button>
  </view>

  <view class="card">
    <text class="title">回流状态</text>
    <text class="hint">坐标系：{{reflowCoordSys}} / 任务：{{reflowTaskId || '未创建'}} / 会话：{{reflowSessionId || '未创建'}}</text>
    <text class="hint">队伍：{{reflowTeamId || 'N/A'}} / 机器人：{{reflowRobotId || 'N/A'}} / 场景：{{reflowSceneId || 'N/A'}}</text>
    <text class="hint">任务状态：{{missionState}} / running={{missionRunning ? 'true' : 'false'}}</text>
    <text class="hint">ROS2：{{ros2Running ? '已启动' : '未启动'}}，录制目录：{{cameraRecordDir || 'N/A'}}</text>
    <text class="hint">媒体目录：{{reflowMediaDir || 'N/A'}}</text>
  </view>

  <view class="card">
    <text class="title">1. 初始化</text>
    <button class="btn btn-main" bindtap="onInitRobot" loading="{{busy}}"><text class="btn-icon">◆</text><text class="btn-label">上电初始化</text></button>
    <view class="input-row">
      <text>音量(0-100)</text>
      <input type="number" value="{{volumePercent}}" bindinput="onVolumeInput" />
    </view>
    <button class="btn" bindtap="onSetVolume" loading="{{busy}}"><text class="btn-icon">♪</text><text class="btn-label">设置音量</text></button>
  </view>

  <view class="card">
    <text class="title">2/3. 移动与转向</text>
    <view class="input-row">
      <text>距离(米)</text>
      <input type="digit" value="{{moveDistance}}" bindinput="onMoveInput" />
    </view>
    <view class="input-row">
      <text>速度(米/秒)</text>
      <input type="digit" value="{{moveSpeed}}" bindinput="onMoveSpeedInput" />
    </view>
    <view class="btn-grid">
      <button class="btn" bindtap="onForward" loading="{{busy}}"><text class="btn-icon">▲</text><text class="btn-label">前进</text></button>
      <button class="btn" bindtap="onBackward" loading="{{busy}}"><text class="btn-icon">▼</text><text class="btn-label">后退</text></button>
    </view>

    <view class="input-row">
      <text>角度(度)</text>
      <input type="digit" value="{{turnAngle}}" bindinput="onTurnInput" />
    </view>
    <view class="btn-grid">
      <button class="btn" bindtap="onTurnLeft" loading="{{busy}}"><text class="btn-icon">◀</text><text class="btn-label">左转</text></button>
      <button class="btn" bindtap="onTurnRight" loading="{{busy}}"><text class="btn-icon">▶</text><text class="btn-label">右转</text></button>
    </view>
  </view>

  <view class="card">
    <text class="title">4/5/6/7. 左右手动作</text>
    <view class="hand-split">
      <view class="side-card side-left">
        <text class="side-title">左手</text>
        <view class="side-actions">
          <button class="btn" bindtap="onLeftExtend" loading="{{busy}}"><text class="btn-icon">↖</text><text class="btn-label">左手前伸</text></button>
          <button class="btn" bindtap="onLeftRetract" loading="{{busy}}"><text class="btn-icon">↙</text><text class="btn-label">左手收回</text></button>
          <button class="btn" bindtap="onLeftGripperOpen" loading="{{busy}}"><text class="btn-icon">⊕</text><text class="btn-label">左手张开</text></button>
          <button class="btn" bindtap="onLeftGripperClose" loading="{{busy}}"><text class="btn-icon">⊖</text><text class="btn-label">左手闭合</text></button>
        </view>
      </view>

      <view class="side-card side-right">
        <text class="side-title">右手</text>
        <view class="side-actions">
          <button class="btn" bindtap="onRightExtend" loading="{{busy}}"><text class="btn-icon">↗</text><text class="btn-label">右手前伸</text></button>
          <button class="btn" bindtap="onRightRetract" loading="{{busy}}"><text class="btn-icon">↘</text><text class="btn-label">右手收回</text></button>
          <button class="btn" bindtap="onRightGripperOpen" loading="{{busy}}"><text class="btn-icon">⊕</text><text class="btn-label">右手张开</text></button>
          <button class="btn" bindtap="onRightGripperClose" loading="{{busy}}"><text class="btn-icon">⊖</text><text class="btn-label">右手闭合</text></button>
        </view>
      </view>
    </view>
  </view>

  <view class="card">
    <text class="title">8. 末端位姿精调（标准档）</text>
    <view class="chip-row">
      <view class="chip {{eefArm==='left' ? 'chip-on' : ''}}" data-arm="left" bindtap="onEefArmChange">左手</view>
      <view class="chip {{eefArm==='right' ? 'chip-on' : ''}}" data-arm="right" bindtap="onEefArmChange">右手</view>
    </view>

    <view class="input-row">
      <text>插值时长(s)</text>
      <input type="digit" value="{{eefSendTime}}" data-key="eefSendTime" bindinput="onEefInput" />
    </view>
    <view class="input-row">
      <text>X(m)</text>
      <input type="digit" value="{{eefX}}" data-key="eefX" bindinput="onEefInput" />
    </view>
    <view class="input-row">
      <text>Y(m)</text>
      <input type="digit" value="{{eefY}}" data-key="eefY" bindinput="onEefInput" />
    </view>
    <view class="input-row">
      <text>Z(m)</text>
      <input type="digit" value="{{eefZ}}" data-key="eefZ" bindinput="onEefInput" />
    </view>
    <view class="input-row">
      <text>Roll(°)</text>
      <input type="digit" value="{{eefRollDeg}}" data-key="eefRollDeg" bindinput="onEefInput" />
    </view>
    <view class="input-row">
      <text>Pitch(°)</text>
      <input type="digit" value="{{eefPitchDeg}}" data-key="eefPitchDeg" bindinput="onEefInput" />
    </view>
    <view class="input-row">
      <text>Yaw(°)</text>
      <input type="digit" value="{{eefYawDeg}}" data-key="eefYawDeg" bindinput="onEefInput" />
    </view>

    <view class="btn-grid">
      <button class="btn" bindtap="onApplyEefAbsolute" loading="{{busy}}"><text class="btn-icon">◎</text><text class="btn-label">绝对位姿下发</text></button>
      <button class="btn" bindtap="onApplyEefDelta" loading="{{busy}}"><text class="btn-icon">△</text><text class="btn-label">增量位姿下发</text></button>
    </view>

    <view class="btn-grid">
      <button class="btn" bindtap="onEefQuickLowerZ" loading="{{busy}}"><text class="btn-icon">⇣</text><text class="btn-label">快速降高(Z-)</text></button>
      <button class="btn" bindtap="onEefQuickLevelRPY" loading="{{busy}}"><text class="btn-icon">⊙</text><text class="btn-label">姿态回正(RPY=0)</text></button>
    </view>

    <view class="input-row">
      <text>步进位置(m)</text>
      <input type="digit" value="{{eefStepPos}}" data-key="eefStepPos" bindinput="onEefInput" />
    </view>
    <view class="input-row">
      <text>步进姿态(°)</text>
      <input type="digit" value="{{eefStepAttDeg}}" data-key="eefStepAttDeg" bindinput="onEefInput" />
    </view>

    <view class="nudge-grid">
      <button class="btn {{eefHoldActive && eefHoldKey==='x:1' ? 'btn-hold-active' : ''}}" data-axis="x" data-sign="1" bindtouchstart="onEefNudgeTouchStart" bindtouchend="onEefNudgeTouchEnd" bindtouchcancel="onEefNudgeTouchCancel" loading="{{busy}}">X+</button>
      <button class="btn {{eefHoldActive && eefHoldKey==='x:-1' ? 'btn-hold-active' : ''}}" data-axis="x" data-sign="-1" bindtouchstart="onEefNudgeTouchStart" bindtouchend="onEefNudgeTouchEnd" bindtouchcancel="onEefNudgeTouchCancel" loading="{{busy}}">X-</button>
      <button class="btn {{eefHoldActive && eefHoldKey==='y:1' ? 'btn-hold-active' : ''}}" data-axis="y" data-sign="1" bindtouchstart="onEefNudgeTouchStart" bindtouchend="onEefNudgeTouchEnd" bindtouchcancel="onEefNudgeTouchCancel" loading="{{busy}}">Y+</button>
      <button class="btn {{eefHoldActive && eefHoldKey==='y:-1' ? 'btn-hold-active' : ''}}" data-axis="y" data-sign="-1" bindtouchstart="onEefNudgeTouchStart" bindtouchend="onEefNudgeTouchEnd" bindtouchcancel="onEefNudgeTouchCancel" loading="{{busy}}">Y-</button>
      <button class="btn {{eefHoldActive && eefHoldKey==='z:1' ? 'btn-hold-active' : ''}}" data-axis="z" data-sign="1" bindtouchstart="onEefNudgeTouchStart" bindtouchend="onEefNudgeTouchEnd" bindtouchcancel="onEefNudgeTouchCancel" loading="{{busy}}">Z+</button>
      <button class="btn {{eefHoldActive && eefHoldKey==='z:-1' ? 'btn-hold-active' : ''}}" data-axis="z" data-sign="-1" bindtouchstart="onEefNudgeTouchStart" bindtouchend="onEefNudgeTouchEnd" bindtouchcancel="onEefNudgeTouchCancel" loading="{{busy}}">Z-</button>
      <button class="btn {{eefHoldActive && eefHoldKey==='r:1' ? 'btn-hold-active' : ''}}" data-axis="r" data-sign="1" bindtouchstart="onEefNudgeTouchStart" bindtouchend="onEefNudgeTouchEnd" bindtouchcancel="onEefNudgeTouchCancel" loading="{{busy}}">R+</button>
      <button class="btn {{eefHoldActive && eefHoldKey==='r:-1' ? 'btn-hold-active' : ''}}" data-axis="r" data-sign="-1" bindtouchstart="onEefNudgeTouchStart" bindtouchend="onEefNudgeTouchEnd" bindtouchcancel="onEefNudgeTouchCancel" loading="{{busy}}">R-</button>
      <button class="btn {{eefHoldActive && eefHoldKey==='p:1' ? 'btn-hold-active' : ''}}" data-axis="p" data-sign="1" bindtouchstart="onEefNudgeTouchStart" bindtouchend="onEefNudgeTouchEnd" bindtouchcancel="onEefNudgeTouchCancel" loading="{{busy}}">P+</button>
      <button class="btn {{eefHoldActive && eefHoldKey==='p:-1' ? 'btn-hold-active' : ''}}" data-axis="p" data-sign="-1" bindtouchstart="onEefNudgeTouchStart" bindtouchend="onEefNudgeTouchEnd" bindtouchcancel="onEefNudgeTouchCancel" loading="{{busy}}">P-</button>
      <button class="btn {{eefHoldActive && eefHoldKey==='yaw:1' ? 'btn-hold-active' : ''}}" data-axis="yaw" data-sign="1" bindtouchstart="onEefNudgeTouchStart" bindtouchend="onEefNudgeTouchEnd" bindtouchcancel="onEefNudgeTouchCancel" loading="{{busy}}">Yaw+</button>
      <button class="btn {{eefHoldActive && eefHoldKey==='yaw:-1' ? 'btn-hold-active' : ''}}" data-axis="yaw" data-sign="-1" bindtouchstart="onEefNudgeTouchStart" bindtouchend="onEefNudgeTouchEnd" bindtouchcancel="onEefNudgeTouchCancel" loading="{{busy}}">Yaw-</button>
    </view>
    <text class="hint">提示：短按=单步微调，长按=连续微调，松开即停。</text>
    <button class="btn btn-stop" wx:if="{{eefHoldActive}}" bindtap="onEefStopHold">停止连续微调</button>

    <text class="hint" wx:if="{{eefActualText}}">{{eefActualText}}</text>
    <button class="btn btn-ghost" bindtap="refreshEefCurrent" loading="{{busy}}"><text class="btn-icon">↺</text><text class="btn-label">读取当前末端位姿</text></button>
  </view>

  <view class="card">
    <text class="title">10/11/12. 相机实时画面（ROS2压缩图）</text>
    <view class="chip-row">
      <view class="chip {{camera==='head' ? 'chip-on' : ''}}" data-camera="head" bindtap="onSelectCamera">头部相机</view>
      <view class="chip {{camera==='left' ? 'chip-on' : ''}}" data-camera="left" bindtap="onSelectCamera">左手相机</view>
      <view class="chip {{camera==='right' ? 'chip-on' : ''}}" data-camera="right" bindtap="onSelectCamera">右手相机</view>
    </view>
    <button class="btn btn-ghost" bindtap="onTogglePreview"><text class="btn-icon">{{cameraPreviewOn ? '■' : '▷'}}</text><text class="btn-label">{{cameraPreviewOn ? '停止预览' : '开始预览'}}</text></button>
    <image wx:if="{{cameraSrc}}" mode="widthFix" src="{{cameraSrc}}" binderror="onCameraError" />
    <text class="hint">后端会自动分别录制头部/左手/右手相机视频到 output/camera 目录。</text>
    <text class="hint" wx:if="{{cameraError}}">{{cameraError}}</text>
  </view>

  <view class="card">
    <text class="title">13. 轨迹回放</text>
    <picker range="{{taskList}}" value="{{taskIndex}}" bindchange="onTaskChange">
      <view class="picker">{{taskList.length ? taskList[taskIndex] : '暂无任务，请检查 config 目录'}}</view>
    </picker>
    <view class="btn-grid">
      <button class="btn btn-ghost" bindtap="loadTasks"><text class="btn-icon">↺</text><text class="btn-label">刷新任务列表</text></button>
      <button class="btn btn-main" bindtap="onPlayTask" loading="{{busy}}"><text class="btn-icon">▶</text><text class="btn-label">按文件回放轨迹</text></button>
    </view>
  </view>

  <view class="card" wx:if="{{lastMsg}}">
    <text class="title">执行反馈</text>
    <text class="hint">{{lastMsg}}</text>
  </view>
</view>
