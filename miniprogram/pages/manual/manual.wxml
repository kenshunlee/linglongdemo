<view class="container">
  <view class="card">
    <view class="row">
      <text class="title">机器人状态</text>
      <text class="badge {{robotReady ? 'badge-success' : 'badge-error'}}">{{robotReady ? 'SDK可用' : 'SDK不可用'}}</text>
    </view>
    <text class="hint">{{sdkReason}}</text>
    <button class="btn btn-ghost" bindtap="refreshHealth" loading="{{busy}}">刷新状态</button>
  </view>

  <view class="card">
    <text class="title">1. 初始化</text>
    <button class="btn btn-main" bindtap="onInitRobot" loading="{{busy}}">上电初始化</button>
  </view>

  <view class="card">
    <text class="title">2/3. 移动与转向</text>
    <view class="input-row">
      <text>距离(米)</text>
      <input type="digit" value="{{moveDistance}}" bindinput="onMoveInput" />
    </view>
    <view class="btn-grid">
      <button class="btn" bindtap="onForward" loading="{{busy}}">前进</button>
      <button class="btn" bindtap="onBackward" loading="{{busy}}">后退</button>
    </view>

    <view class="input-row">
      <text>角度(度)</text>
      <input type="digit" value="{{turnAngle}}" bindinput="onTurnInput" />
    </view>
    <view class="btn-grid">
      <button class="btn" bindtap="onTurnLeft" loading="{{busy}}">左转</button>
      <button class="btn" bindtap="onTurnRight" loading="{{busy}}">右转</button>
    </view>
  </view>

  <view class="card">
    <text class="title">4/5. 夹爪</text>
    <view class="btn-grid">
      <button class="btn" bindtap="onGripperOpen" loading="{{busy}}">张开夹爪</button>
      <button class="btn" bindtap="onGripperClose" loading="{{busy}}">闭合夹爪</button>
    </view>
  </view>

  <view class="card">
    <text class="title">6/7/8/9. 双手预置动作</text>
    <view class="btn-grid">
      <button class="btn" bindtap="onLeftExtend" loading="{{busy}}">左手前伸</button>
      <button class="btn" bindtap="onLeftRetract" loading="{{busy}}">左手收回</button>
      <button class="btn" bindtap="onRightExtend" loading="{{busy}}">右手前伸</button>
      <button class="btn" bindtap="onRightRetract" loading="{{busy}}">右手收回</button>
    </view>
  </view>

  <view class="card">
    <text class="title">10/11/12. 相机实时画面（轮询近实时）</text>
    <view class="chip-row">
      <view class="chip {{camera==='head' ? 'chip-on' : ''}}" data-camera="head" bindtap="onSelectCamera">头部相机</view>
      <view class="chip {{camera==='left' ? 'chip-on' : ''}}" data-camera="left" bindtap="onSelectCamera">左手相机</view>
      <view class="chip {{camera==='right' ? 'chip-on' : ''}}" data-camera="right" bindtap="onSelectCamera">右手相机</view>
    </view>
    <button class="btn btn-ghost" bindtap="onTogglePreview">{{cameraPreviewOn ? '停止预览' : '开始预览'}}</button>
    <image wx:if="{{cameraSrc}}" mode="widthFix" src="{{cameraSrc}}" binderror="onCameraError" />
    <text class="hint" wx:if="{{cameraError}}">{{cameraError}}</text>
  </view>

  <view class="card">
    <text class="title">13. 轨迹回放</text>
    <picker range="{{taskList}}" value="{{taskIndex}}" bindchange="onTaskChange">
      <view class="picker">{{taskList.length ? taskList[taskIndex] : '暂无任务，请检查 config 目录'}}</view>
    </picker>
    <view class="btn-grid">
      <button class="btn btn-ghost" bindtap="loadTasks">刷新任务列表</button>
      <button class="btn btn-main" bindtap="onPlayTask" loading="{{busy}}">按文件回放轨迹</button>
    </view>
  </view>

  <view class="card" wx:if="{{lastMsg}}">
    <text class="title">执行反馈</text>
    <text class="hint">{{lastMsg}}</text>
  </view>
</view>
