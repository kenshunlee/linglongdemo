.row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.title {
  font-size: 30rpx;
  font-weight: 600;
  color: #243247;
  display: block;
  margin-bottom: 12rpx;
}

.hint {
  font-size: 24rpx;
  color: #55657f;
  line-height: 1.6;
  display: block;
}

.btn {
  margin-top: 12rpx;
  border-radius: 12rpx !important;
  background: #e9eef6 !important;
  color: #243247 !important;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
}

.btn-icon {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  background: rgba(15, 110, 168, 0.12);
  color: #0f6ea8;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 1;
}

.btn-label {
  font-size: 28rpx;
  line-height: 1.2;
}

.hand-split {
  display: flex;
  gap: 16rpx;
  align-items: stretch;
}

.side-card {
  flex: 1;
  padding: 18rpx;
  border-radius: 16rpx;
  border: 1rpx solid #dbe7f5;
  background: linear-gradient(180deg, #f8fbff 0%, #f2f7fd 100%);
  box-sizing: border-box;
}

.side-title {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: #243247;
  text-align: center;
  margin-bottom: 12rpx;
}

.side-actions {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.side-actions .btn {
  width: 100%;
  margin-top: 0;
}

.btn-main {
  background: #0f6ea8 !important;
  color: #ffffff !important;
}

.btn-ghost {
  background: #ffffff !important;
  color: #0f6ea8 !important;
  border: 2rpx solid #0f6ea8 !important;
}

.btn-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12rpx;
}

.input-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
  margin: 12rpx 0;
}

.input-row input {
  flex: 1;
  border: 1rpx solid #ced9ea;
  border-radius: 8rpx;
  padding: 12rpx 14rpx;
}

.chip-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin: 10rpx 0;
}

.chip {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: #edf1f7;
  color: #425575;
  font-size: 24rpx;
}

.chip-on {
  background: #0f6ea8;
  color: #fff;
}

.picker {
  border: 1rpx solid #ced9ea;
  border-radius: 10rpx;
  padding: 16rpx;
  color: #2c3b53;
  margin-top: 8rpx;
}

image {
  margin-top: 14rpx;
  border-radius: 10rpx;
  width: 100%;
  background: #f3f6fb;
}
