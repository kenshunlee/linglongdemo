<!-- pages/index/index.wxml — 录音主页 -->
<view class="container">

  <!-- 顶部：服务状态 -->
  <view class="card status-card">
    <view class="status-row">
      <text class="status-label">后端服务</text>
      <view class="status-dot {{serverConnected ? 'dot-on' : 'dot-off'}}"></view>
      <text class="status-text">{{serverConnected ? '已连接' : '未连接'}}</text>
    </view>
    <view class="status-row" wx:if="{{serverConnected}}">
      <text class="status-label">ASR 引擎</text>
      <text class="status-text small">{{asrProvider || 'unknown'}} / {{asrModel || 'unknown'}} {{zhipuConfigured ? '(已配置)' : '(未配置API Key)'}}</text>
    </view>
    <view class="server-url" bindtap="onEditServer">
      <text class="url-text">{{serverBase}}</text>
      <text class="edit-hint">点击修改</text>
    </view>
  </view>

  <!-- 录音区域 -->
  <view class="card record-card">
    <view class="record-title">语音录入</view>
    <view class="record-tip">按住按钮开始录音，松开后自动转写</view>

    <!-- 波形动画（录音时显示） -->
    <view class="wave-container" wx:if="{{isRecording}}">
      <view class="wave-bar {{isRecording ? 'wave-animate' : ''}}" wx:for="{{[1,2,3,4,5,6,7]}}" wx:key="index"
            style="animation-delay: {{index * 0.1}}s"></view>
    </view>

    <!-- 录音时长 -->
    <view class="record-duration" wx:if="{{isRecording}}">
      <text>{{recordDurationText}}</text>
    </view>

    <!-- 录音按钮 -->
    <view class="mic-btn-wrap">
      <view class="mic-btn {{isRecording ? 'mic-btn-active' : ''}} {{!serverConnected ? 'mic-btn-disabled' : ''}}"
            bindtouchstart="onRecordStart"
            bindtouchend="onRecordEnd"
            catchtouchmove="onRecordCancel">
        <view class="mic-icon">
          <text wx:if="{{!isRecording}}">🎤</text>
          <text wx:else>⏹</text>
        </view>
        <text class="mic-label">{{isRecording ? '松开结束' : '按住录音'}}</text>
      </view>
    </view>

    <!-- 或上传音频文件 -->
    <view class="divider">
      <view class="divider-line"></view>
      <text class="divider-text">或</text>
      <view class="divider-line"></view>
    </view>
    <view class="upload-btn" bindtap="onChooseFile">
      <text>📂 选择音频文件</text>
    </view>
  </view>

  <!-- 处理中状态 -->
  <view class="card processing-card" wx:if="{{isProcessing}}">
    <view class="processing-inner">
      <view class="spinner"></view>
      <view class="processing-info">
        <text class="processing-title">转写中...</text>
        <text class="processing-sub">{{processingStep}}</text>
      </view>
    </view>
    <view class="progress-bar">
      <view class="progress-fill" style="width: {{uploadProgress}}%"></view>
    </view>
    <text class="progress-text">{{uploadProgress}}%</text>
  </view>

  <!-- 转写结果 -->
  <view class="card result-card" wx:if="{{lastResult}}">
    <view class="result-header">
      <text class="result-title">转写结果</text>
      <view class="result-meta">
        <text class="badge badge-{{engineBadge}}">{{lastResult.engine}}</text>
      </view>
    </view>
    <view class="result-filename">
      <text class="file-icon">📄</text>
      <text class="filename">{{lastResult.filename}}</text>
    </view>
    <view class="result-text-wrap">
      <text class="result-text" selectable>{{lastResult.text}}</text>
    </view>
    <view class="result-actions">
      <button class="btn-copy" size="mini" bindtap="onCopyText">复制文本</button>
      <button class="btn-share" size="mini" bindtap="onShareResult">分享</button>
    </view>
  </view>

  <!-- 错误提示 -->
  <view class="card error-card" wx:if="{{errorMsg}}">
    <text class="error-icon">⚠️</text>
    <text class="error-msg">{{errorMsg}}</text>
    <view class="error-help" wx:if="{{showHelp}}">
      <text class="help-title">可能的解决方法：</text>
      <text class="help-item">1. 确保电脑已运行 backend/start.bat</text>
      <text class="help-item">2. 手机与电脑在同一 WiFi</text>
      <text class="help-item">3. 检查 IP 地址是否正确</text>
      <text class="help-item">4. 检查后端是否配置 ZHIPU_API_KEY</text>
    </view>
  </view>

</view>

<!-- 修改服务器地址弹窗 -->
<view class="modal-mask" wx:if="{{showServerModal}}" bindtap="onCloseModal">
  <view class="modal-box" catchtap="">
    <text class="modal-title">修改服务器地址</text>
    <input class="modal-input" value="{{serverInput}}"
           bindinput="onServerInput"
           placeholder="http://192.168.x.x:8765" />
    <view class="modal-btns">
      <button class="modal-btn-cancel" bindtap="onCloseModal">取消</button>
      <button class="modal-btn-ok" bindtap="onSaveServer">保存</button>
    </view>
  </view>
</view>
